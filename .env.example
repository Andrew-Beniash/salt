# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development                        # development | staging | production
APP_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-long-random-string
CORS_ORIGINS=http://localhost:3000

# ─── Database (PostgreSQL 16) ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://salt:salt@db:5432/salt

# ─── Cache & Message Broker (Redis 7) ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Authentication (Supabase) ────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_JWT_SECRET=<supabase-jwt-secret>

# ─── AI / OpenAI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini                   # gpt-4o-mini (prototype) | gpt-4o (production)

# ─── OCR / Azure Document Intelligence ───────────────────────────────────────
AZURE_DI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=<azure-document-intelligence-key>

# ─── OCR Confidence Thresholds ───────────────────────────────────────────────
OCR_TIER1_CONFIDENCE_THRESHOLD=0.95        # pdfplumber → pass-through threshold
OCR_TIER2_CONFIDENCE_THRESHOLD=0.80        # Azure DI → pass-through threshold

# ─── Microsoft / OneDrive Integration ────────────────────────────────────────
MICROSOFT_CLIENT_ID=<azure-app-client-id>
MICROSOFT_CLIENT_SECRET=<azure-app-client-secret>
MICROSOFT_TENANT_ID=<azure-tenant-id>

# ─── Credential Encryption ───────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=<fernet-symmetric-encryption-key>

# ─── File Storage ────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                      # local | azure_blob
STORAGE_PATH=/storage                      # used when STORAGE_BACKEND=local

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid                    # sendgrid | smtp
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@example.com

# ─── Celery / Flower ─────────────────────────────────────────────────────────
FLOWER_BASIC_AUTH=admin:change-me          # user:password for Flower dashboard
